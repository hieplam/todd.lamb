---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { getPostHeroImage } from "@/utils/getPostHeroImage";
import { toTransitionName } from "@/utils/toTransitionName";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;

const href = getPostUrl(id, filePath, Astro.currentLocale);
const heroImage = getPostHeroImage(id);

const LANG_BADGE: Record<string, { flag: string; label: string }> = {
  vi: { flag: "🇻🇳", label: "VI" },
  en: { flag: "🇺🇸", label: "EN" },
};
const langBadge = LANG_BADGE[data.lang ?? "vi"] ?? LANG_BADGE["vi"];
---

<li class="my-8 grid items-start gap-x-5 gap-y-3 sm:grid-cols-[220px_1fr]">
  {
    heroImage && (
      <a href={href} tabindex="-1" aria-hidden="true" class="group">
        <img
          src={heroImage}
          alt=""
          width="1600"
          height="900"
          loading="lazy"
          decoding="async"
          class="border-border aspect-[16/10] w-full rounded-lg border object-cover transition-transform duration-300 ease-out group-hover:scale-[1.02] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
        />
      </a>
    )
  }
  <div>
    <a
      href={href}
      class:list={[
        "text-foreground inline-block text-lg font-bold",
        "hover:text-accent decoration-dashed underline-offset-4 hover:underline",
        "focus-visible:no-underline focus-visible:underline-offset-0",
      ]}
    >
      <Heading transition:name={toTransitionName(title)}>
        {title}
      </Heading>
    </a>
    <div class="mt-1 flex items-center gap-2">
      <Datetime {...props} />
      <span class="text-muted-foreground border-border rounded border px-1 py-0.5 text-xs font-medium leading-none">
        {langBadge.flag} {langBadge.label}
      </span>
    </div>
    <p class="text-muted-foreground mt-2">{description}</p>
  </div>
</li>
